<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">customersegment_segment_listing.customersegment_segment_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Add New Segment</label>
            </button>
        </buttons>
        <spinner>customersegment_segment_columns</spinner>
        <deps>
            <dep>customersegment_segment_listing.customersegment_segment_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="customersegment_segment_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">segment_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Magendoo_CustomerSegment::segments</aclResource>
        <dataProvider class="Magendoo\CustomerSegment\Ui\DataProvider\SegmentDataProvider" name="customersegment_segment_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>segment_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filterSearch name="keyword"/>
        <filters name="listing_filters"/>
        <massaction name="listing_massaction">
            <action name="delete">
                <settings>
                    <confirm>
                        <message translate="true">Are you sure you want to delete selected items?</message>
                        <title translate="true">Delete items</title>
                    </confirm>
                    <url path="*/*/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Delete</label>
                </settings>
            </action>
            <action name="refresh">
                <settings>
                    <confirm>
                        <message translate="true">Are you sure you want to refresh the selected segments?</message>
                        <title translate="true">Refresh Segments</title>
                    </confirm>
                    <url path="*/*/massRefresh"/>
                    <type>refresh</type>
                    <label translate="true">Refresh</label>
                </settings>
            </action>
        </massaction>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="customersegment_segment_columns">
        <selectionsColumn name="ids">
            <settings>
                <indexField>segment_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="segment_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>
        <column name="name">
            <settings>
                <filter>text</filter>
                <editor>
                    <validation>
                        <rule name="required-entry" xsi:type="boolean">true</rule>
                    </validation>
                    <editorType>text</editorType>
                </editor>
                <label translate="true">Segment Name</label>
            </settings>
        </column>
        <column name="is_active" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Magendoo\CustomerSegment\Model\Source\Status"/>
                <filter>select</filter>
                <editor>
                    <editorType>select</editorType>
                </editor>
                <dataType>select</dataType>
                <label translate="true">Status</label>
            </settings>
        </column>
        <column name="customer_count">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Customer Count</label>
            </settings>
        </column>
        <column name="refresh_mode" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Magendoo\CustomerSegment\Model\Source\RefreshMode"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Refresh Mode</label>
            </settings>
        </column>
        <column name="last_refreshed" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Last Refreshed</label>
            </settings>
        </column>
        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Created</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="Magendoo\CustomerSegment\Ui\Component\Listing\Column\Actions">
            <settings>
                <indexField>segment_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
