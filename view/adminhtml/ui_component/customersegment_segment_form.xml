<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">customersegment_segment_form.segment_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Segment Information</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <buttons>
            <button name="save" class="Magendoo\CustomerSegment\Block\Adminhtml\Segment\Edit\SaveButton"/>
            <button name="delete" class="Magendoo\CustomerSegment\Block\Adminhtml\Segment\Edit\DeleteButton"/>
            <button name="back" class="Magendoo\CustomerSegment\Block\Adminhtml\Segment\Edit\BackButton"/>
        </buttons>
        <namespace>customersegment_segment_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>customersegment_segment_form.segment_form_data_source</dep>
        </deps>
    </settings>
    <dataSource name="segment_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="customersegment/segment/save"/>
        </settings>
        <dataProvider class="Magendoo\CustomerSegment\Ui\DataProvider\Form\SegmentDataProvider" name="segment_form_data_source">
            <settings>
                <requestFieldName>segment_id</requestFieldName>
                <primaryFieldName>segment_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="general">
        <settings>
            <label/>
        </settings>
        <field name="segment_id" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">segment</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
                <dataScope>segment_id</dataScope>
            </settings>
        </field>
        <field name="name" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">segment</item>
                </item>
            </argument>
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Segment Name</label>
                <dataScope>name</dataScope>
            </settings>
        </field>
        <field name="description" formElement="textarea">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">segment</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Description</label>
                <dataScope>description</dataScope>
            </settings>
        </field>
        <field name="is_active" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">segment</item>
                    <item name="default" xsi:type="number">1</item>
                </item>
            </argument>
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Active</label>
                <dataScope>is_active</dataScope>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="number">0</map>
                            <map name="true" xsi:type="number">1</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
        <field name="refresh_mode" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="options" xsi:type="object">Magendoo\CustomerSegment\Model\Source\RefreshMode</item>
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">segment</item>
                    <item name="default" xsi:type="string">manual</item>
                </item>
            </argument>
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Refresh Mode</label>
                <dataScope>refresh_mode</dataScope>
            </settings>
        </field>
        <field name="cron_expression" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">segment</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Cron Expression</label>
                <dataScope>cron_expression</dataScope>
                <notice translate="true">Example: 0 2 * * * (daily at 2 AM)</notice>
            </settings>
        </field>
        <field name="customer_count" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">segment</item>
                    <item name="disabled" xsi:type="boolean">true</item>
                </item>
            </argument>
            <settings>
                <dataType>number</dataType>
                <label translate="true">Customer Count</label>
                <dataScope>customer_count</dataScope>
            </settings>
        </field>
        <field name="last_refreshed" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">segment</item>
                    <item name="disabled" xsi:type="boolean">true</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Last Refreshed</label>
                <dataScope>last_refreshed</dataScope>
            </settings>
        </field>
    </fieldset>
    
    <fieldset name="conditions">
        <settings>
            <label translate="true">Conditions</label>
            <collapsible>true</collapsible>
            <opened>true</opened>
        </settings>
        <htmlContent name="conditions_content">
            <block name="segment.conditions" class="Magendoo\CustomerSegment\Block\Adminhtml\Segment\Edit\Conditions"/>
        </htmlContent>
    </fieldset>
</form>
