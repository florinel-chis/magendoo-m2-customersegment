{
    "name": "magendoo/module-customer-segment",
    "description": "Magento 2 dynamic customer segmentation module — rule-based segments with admin UI, REST API, CLI, and Cart Price Rule integration.",
    "type": "magento2-module",
    "version": "1.1.0",
    "license": "MIT",
    "authors": [
        {
            "name": "Magendoo",
            "homepage": "https://magendoo.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "magento/framework": ">=103.0.0",
        "magento/module-customer": ">=103.0.0",
        "magento/module-sales": ">=103.0.0",
        "magento/module-quote": ">=101.2.0",
        "magento/module-rule": ">=100.4.0",
        "magento/module-backend": ">=102.0.0",
        "magento/module-ui": ">=101.2.0",
        "magento/module-catalog": ">=104.0.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10 || ^2.0"
    },
    "autoload": {
        "files": ["registration.php"],
        "psr-4": {
            "Magendoo\\CustomerSegment\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Magendoo\\CustomerSegment\\Test\\": "Test/"
        }
    },
    "scripts": {
        "test": "phpunit --testdox",
        "analyse": "phpstan analyse --no-progress"
    },
    "config": {
        "allow-plugins": {
            "magento/magento-composer-installer": true
        }
    }
}
